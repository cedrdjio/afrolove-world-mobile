{
  "expo": {
    "name": "Afrilove World",
    "slug": "afrolove-world-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "afrilove",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F8F4EE"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "world.afrilove.app"
    },
    "android": {
      "package": "world.afrilove.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F8F4EE"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Afrilove uses your location to show people near you."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Afrilove needs access to your photos to set your profile pictures and verify your identity."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 180,
          "resizeMode": "contain",
          "backgroundColor": "#F8F4EE"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "supabase": {
        "url": "https://sbvlkjaifqocakgxvdea.supabase.co",
        "publishableKey": "sb_publishable_vewP1o3kkTF2-J9_8SugDA_G5AA5_Gy"
      },
      "firebase": {
        "apiKey": "AIzaSyDJINNe9iwb6_GYsLi6V_XfTUxgaywuCRE",
        "authDomain": "afrilove-world.firebaseapp.com",
        "projectId": "afrilove-world",
        "storageBucket": "afrilove-world.firebasestorage.app",
        "messagingSenderId": "949332317190",
        "appId": "1:949332317190:android:f729fb77c3fe3f8279df87"
      }
    }
  }
}
